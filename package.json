{
  "name": "gtlua",
  "version": "0.4.2",
  "type": "module",
  "bin": {
    "gtlua": "bin/gtlua.js"
  },
  "exports": {
    "./compiler/index.js": "./compiler/index.js",
    "./compiler/peephole.js": "./compiler/peephole.js",
    "./compiler/builtins.js": "./compiler/builtins.js",
    "./compiler/gt_palette.js": "./compiler/gt_palette.js",
    "./compiler/gfx.mjs": "./compiler/gfx.mjs",
    "./compiler/frames.js": "./compiler/frames.js",
    "./compiler/gtm2.mjs": "./compiler/gtm2.mjs",
    "./build": "./compiler/build.js",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "luacretro": "^0.1.0",
    "romdev-core-gametank": "0.3.0",
    "romdev-core-runner": "0.1.0",
    "romdev-toolchain-cc65": "0.1.3"
  },
  "scripts": {
    "test": "node --test 'test/**/*.test.js'",
    "bench": "node bench/run.mjs"
  },
  "description": "Write GameTank games in a PICO-8-flavored Lua that ahead-of-time compiles to native 65C02. Bundled cc65 WASM toolchain + emulator, .gtr cartridges, no native tools.",
  "keywords": [
    "lua",
    "pico-8",
    "pico8",
    "gamedev",
    "game-development",
    "retro",
    "retrogaming",
    "homebrew",
    "rom",
    "wasm",
    "webassembly",
    "ahead-of-time",
    "aot",
    "gametank",
    "6502",
    "65c02",
    "cc65",
    "fantasy-console",
    "8-bit",
    "cartridge",
    "gtr",
    "blitter"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/monteslu/gametank_lua_sdk.git"
  },
  "homepage": "https://github.com/monteslu/gametank_lua_sdk#readme",
  "bugs": {
    "url": "https://github.com/monteslu/gametank_lua_sdk/issues"
  }
}
